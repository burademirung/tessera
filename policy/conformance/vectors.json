			"want_allow": false
		},
		{
			"name": "cross-tenant read (BOLA) -> deny",
			"input": {"subject": {"id": "u1", "roles": ["reader"], "tenant": "t1", "mfa": true}, "resource": {"type": "user", "id": "r1", "tenant": "t2"}, "action": "read", "environment": {"now_epoch": 1782259200, "device_posture": "managed"}},
			"want_allow": false
		},
		{
