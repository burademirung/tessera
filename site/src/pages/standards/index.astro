---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import TechnologyCard from '../../components/TechnologyCard.astro';
import { getCollection } from 'astro:content';

const techs = (await getCollection('technologies')).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<Base title="Standards & technologies — Tessera" description="Every technology in the Tessera identity engine, the standards it follows, and the best practices applied — each claim citation-backed.">
  <main id="main" class="page">
    <div class="wrap">
      <p class="eyebrow">STANDARDS &amp; TECHNOLOGIES</p>
      <h1 class="page__h1">Standards &amp; technologies</h1>
      <p class="page__lede">
        Each technology is built to the standards it follows, with the best
        practices applied — and every claim is backed by a cited source.
        Everything here is also on the <a href="/#technologies">single page</a>.
      </p>
      <div class="cardgrid">
        {techs.map((t) => (
          <TechnologyCard id={t.id} name={t.data.name} tagline={t.data.tagline} />
        ))}
      </div>
    </div>
  </main>
</Base>
<style>
  .page { padding-block: clamp(48px, 8vw, 96px); }
  .page__h1 { font-size: clamp(2rem, 5vw, 3rem); margin: var(--space-2) 0; }
  .page__lede { color: var(--muted); font-size: 1.15rem; max-width: var(--measure); }
  .cardgrid {
    display: grid; gap: var(--space-3); margin-top: var(--space-5);
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
