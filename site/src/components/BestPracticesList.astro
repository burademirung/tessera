---
interface Item { claim: string; sourceUrl: string }
interface Props { items: Item[] }
const { items } = Astro.props;
---
<ul class="practices">
  {items.map((i) => (
    <li>
      <span>{i.claim}</span>
      {' '}
      <a class="practices__src" href={i.sourceUrl} rel="noopener noreferrer">source</a>
    </li>
  ))}
</ul>
<style>
  .practices { margin: 0; padding: 0; list-style: none; display: grid; gap: var(--space-2); }
  .practices li {
    max-width: var(--measure);
    position: relative;
    padding-left: 22px;
  }
  /* Mosaic tessera bullet */
  .practices li::before {
    content: '';
    position: absolute; left: 0; top: 0.55em;
    width: 8px; height: 8px;
    background: var(--lapis);
    border-radius: 2px;
    transform: translateY(-50%) rotate(45deg);
  }
  .practices__src {
    color: var(--lapis); font-family: var(--font-mono); font-size: 0.72rem;
    text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap;
  }
</style>
