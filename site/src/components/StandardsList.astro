---
interface Standard { name: string; rfc?: string; url: string }
interface Props { standards: Standard[] }
const { standards } = Astro.props;
---
<dl class="standards">
  {standards.map((s) => (
    <div class="standards__row">
      <dt>
        {s.name}
        {s.rfc ? <span class="standards__rfc">{s.rfc}</span> : null}
      </dt>
      <dd><a href={s.url} rel="noopener noreferrer">{s.url}</a></dd>
    </div>
  ))}
</dl>
<style>
  .standards { margin: 0; display: grid; gap: 0; }
  .standards__row {
    display: grid; gap: 3px;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--line);
  }
  .standards__row:first-child { padding-top: 0; }
  .standards dt { font-weight: 600; display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px; }
  /* RFC tag — mono, gold standard-token marker */
  .standards__rfc {
    font-family: var(--font-mono); font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.02em; color: var(--gold);
    border: 1px solid var(--line); border-radius: var(--radius-sm);
    padding: 1px 7px; background: var(--gold-soft);
  }
  .standards dd { margin: 0; }
  .standards a { color: var(--lapis); word-break: break-all; font-size: 0.86rem; }
</style>
