---
import CodeBlock from './CodeBlock.astro';
import StandardsList from './StandardsList.astro';
import BestPracticesList from './BestPracticesList.astro';
import type { CollectionEntry } from 'astro:content';
interface Props {
  data: CollectionEntry<'technologies'>['data'];
  /** When true, render the body inside a <details> tile (inline single-page use). */
  expandable?: boolean;
  /** Heading level for the technology name (h2 standalone page, h3 inline). */
  level?: 2 | 3;
}
const { data, expandable = false, level = 2 } = Astro.props;
const HeadingTag = `h${level}` as 'h2' | 'h3';
const SubTag = `h${level + 1}` as 'h3' | 'h4';
const anchor = `tech-${data.requirementKey}`;
---
<article class="tech tile" id={anchor} aria-labelledby={`${anchor}-h`}>
  {expandable ? (
    <details class="tech__details">
      <summary class="tech__summary">
        <span class="tech__mark" aria-hidden="true"></span>
        <span class="tech__heads">
          <HeadingTag id={`${anchor}-h`} class="tech__name">{data.name}</HeadingTag>
          <span class="tech__tagline">{data.tagline}</span>
        </span>
        <span class="tech__chev" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </span>
      </summary>
      <div class="tech__panel">
        <div class="tech__body"><slot /></div>
        <SubTag class="tech__sub">Code</SubTag>
        <CodeBlock code={data.codeSample} lang={data.codeLang} label={`${data.name} code sample`} />
        <div class="tech__cols">
          <div>
            <SubTag class="tech__sub">Standards it follows</SubTag>
            <StandardsList standards={data.standards} />
          </div>
          <div>
            <SubTag class="tech__sub">Best practices applied</SubTag>
            <BestPracticesList items={data.bestPractices} />
          </div>
        </div>
      </div>
    </details>
  ) : (
    <div class="tech__panel tech__panel--open">
      <HeadingTag id={`${anchor}-h`} class="tech__name">{data.name}</HeadingTag>
      <p class="tech__tagline">{data.tagline}</p>
      <div class="tech__body"><slot /></div>
      <SubTag class="tech__sub">Code</SubTag>
      <CodeBlock code={data.codeSample} lang={data.codeLang} label={`${data.name} code sample`} />
      <SubTag class="tech__sub">Standards it follows</SubTag>
      <StandardsList standards={data.standards} />
      <SubTag class="tech__sub">Best practices applied</SubTag>
      <BestPracticesList items={data.bestPractices} />
    </div>
  )}
</article>
<style>
  .tech { scroll-margin-top: 72px; overflow: hidden; }
  .tech__details { }
  .tech__summary {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    cursor: pointer; list-style: none;
    transition: background var(--dur-standard) var(--ease-standard);
  }
  .tech__summary::-webkit-details-marker { display: none; }
  .tech__summary:hover { background: var(--gold-soft); }
  .tech__mark {
    flex: none; width: 11px; height: 11px;
    background: var(--gold); border-radius: 2px; transform: rotate(45deg);
  }
  .tech__heads { display: grid; gap: 3px; }
  .tech__name { font-family: var(--font-display); font-weight: 520; margin: 0; }
  .tech__details .tech__name { font-size: 1.25rem; }
  .tech__tagline { color: var(--muted); font-size: 0.95rem; line-height: 1.5; }
  .tech__chev { margin-left: auto; color: var(--muted); display: inline-flex; transition: transform var(--dur-standard) var(--ease-standard); }
  .tech__details[open] .tech__chev { transform: rotate(180deg); }
  .tech__panel { padding: 0 var(--space-4) var(--space-4); }
  .tech__panel--open { padding: var(--space-4); }
  .tech__panel--open .tech__name { font-size: 1.6rem; }
  .tech__panel--open .tech__tagline { margin-top: 4px; }
  .tech__body { max-width: var(--measure); color: var(--ink); }
  .tech__sub {
    font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--muted); font-weight: 500;
    margin: var(--space-4) 0 var(--space-2); display: flex; align-items: center; gap: 8px;
  }
  .tech__sub::before { content: ''; width: 7px; height: 7px; background: var(--lapis); border-radius: 1px; transform: rotate(45deg); }
  .tech__cols { display: grid; gap: var(--space-4); grid-template-columns: 1fr; }
  @media (min-width: 760px) { .tech__cols { grid-template-columns: 1fr 1fr; } }
</style>
