{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "noUnusedLocals": true,
    "noImplicitAny": true,
    "types": ["node", "jest"]
  },
  "exclude": ["cdk.out", "node_modules"]
}
